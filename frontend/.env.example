# API
# Safe public value only. Do not put JWT secrets or tokens in frontend env.
VITE_API_URL=http://localhost:8000/api

# Cloudflare Turnstile
# Create a Turnstile widget in Cloudflare and place the public site key here.
# The matching secret key belongs in backend/.env as TURNSTILE_SECRET_KEY.
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
