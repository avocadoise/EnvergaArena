# Django Settings
SECRET_KEY=django-insecure-replace-this-with-a-real-one
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME

# JWT Auth
# Access tokens are returned to the frontend and kept in memory only.
# Refresh tokens are stored by the backend in an HttpOnly cookie.
JWT_SECRET_KEY=replace_this_with_a_long_random_jwt_signing_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=False
JWT_BLACKLIST_AFTER_ROTATION=False
JWT_UPDATE_LAST_LOGIN=True
JWT_REFRESH_COOKIE_NAME=enverga_refresh
JWT_REFRESH_COOKIE_SECURE=False
JWT_REFRESH_COOKIE_HTTPONLY=True
JWT_REFRESH_COOKIE_SAMESITE=Lax
JWT_REFRESH_COOKIE_DOMAIN=
JWT_REFRESH_COOKIE_PATH=/

# AI Services
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_PRIMARY_MODEL=gemini-2.5-flash-lite
GEMINI_BACKUP_MODELS=gemini-2.5-flash,gemini-2.0-flash-lite

# Cloudflare Turnstile
# Create keys in Cloudflare Turnstile, then put the secret key here.
# The matching frontend site key belongs in frontend/.env as VITE_TURNSTILE_SITE_KEY.
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Brevo Transactional Email
# Configure the sender in Brevo before using these values.
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=no-reply@example.edu.ph
BREVO_SENDER_NAME=Enverga Arena

# Public Tryout Verification
TRYOUT_ALLOWED_EMAIL_DOMAIN=@student.mseuf.edu.ph
TRYOUT_OTP_EXPIRY_MINUTES=10
TRYOUT_VERIFIED_APPLICATION_WINDOW_MINUTES=30
TRYOUT_MAX_VERIFY_ATTEMPTS=5
TRYOUT_MAX_OTP_REQUESTS_PER_HOUR=3
TRYOUT_MAX_APPLICATIONS_PER_HOUR=5
