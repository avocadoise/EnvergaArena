# Django Settings
SECRET_KEY=django-insecure-replace-this-with-a-real-one
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME

# AI Services
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_PRIMARY_MODEL=gemini-2.5-flash-lite
GEMINI_BACKUP_MODELS=gemini-2.5-flash,gemini-2.0-flash-lite

# Cloudflare Turnstile
# Create keys in Cloudflare Turnstile, then put the secret key here.
# The matching frontend site key belongs in frontend/.env as VITE_TURNSTILE_SITE_KEY.
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Brevo Transactional Email
# Configure the sender in Brevo before using these values.
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=no-reply@example.edu.ph
BREVO_SENDER_NAME=Enverga Arena

# Public Tryout Verification
TRYOUT_ALLOWED_EMAIL_DOMAIN=@student.mseuf.edu.ph
TRYOUT_OTP_EXPIRY_MINUTES=10
TRYOUT_VERIFIED_APPLICATION_WINDOW_MINUTES=30
TRYOUT_MAX_VERIFY_ATTEMPTS=5
TRYOUT_MAX_OTP_REQUESTS_PER_HOUR=3
TRYOUT_MAX_APPLICATIONS_PER_HOUR=5
